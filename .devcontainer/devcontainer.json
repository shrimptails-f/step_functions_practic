{
    "name": "Step Functions Practice DevContainer",
    "dockerComposeFile": "docker-compose.yml",
    "service": "infra",
    "workspaceFolder": "/home/dev/infra",
    "customizations": {
        "vscode": {
            "extensions": [
                "editorconfig.editorconfig", // エディタを跨いだ共通設定ファイルをVsCodeで実行するのに必要
                "ms-azuretools.vscode-docker", // VsCodeでのIntelliSenseやタブ補完用
                "streetsidesoftware.code-spell-checker", // スペルチェック
                "hashicorp.terraform", // Terraform公式拡張機能
                "hediet.vscode-drawio", // draw.io
                "sztheory.vscode-packer-powertools" // packer
            ]
        }
    }
}